generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  EXTERNAL
  PARTNER
  INTERNAL
  RELATIONSHIP_MANAGER
  ADMIN
}

enum OrgType {
  PARTNER
  INTERNAL
}

enum ProductStatus {
  GA
  BETA
  COMING_SOON
  DEPRECATED
}

enum Visibility {
  PUBLIC
  PARTNER
  INTERNAL
}

enum AssignmentStatus {
  ACTIVE
  INACTIVE
}

enum AccessLevel {
  READ_DOCS
  TEST_SANDBOX
  FULL_PRODUCTION
}

enum ApiKeyEnvironment {
  TEST
  PRODUCTION
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// ─── Core Entities ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  role         UserRole @default(EXTERNAL)
  orgId        String?
  authProvider String   @default("credentials")
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?

  organization        Organization?        @relation(fields: [orgId], references: [id], onDelete: SetNull)
  apiKeys             ApiKey[]
  partnerAssignments  PartnerAssignment[]
  grantedAccesses     PartnerProductAccess[]
  changelogs          Changelog[]
  docFeedbacks        DocFeedback[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  type      OrgType
  website   String?
  createdAt DateTime @default(now())

  users                User[]
  partnerAssignments   PartnerAssignment[]
  partnerProductAccess PartnerProductAccess[]

  @@map("organizations")
}

model Product {
  id               String        @id @default(uuid())
  slug             String        @unique
  name             String
  description      String        @db.Text
  categoryId       String
  status           ProductStatus @default(GA)
  visibility       Visibility    @default(PUBLIC)
  iconUrl          String?
  interactionTypes String[]
  openapiSpecPath  String?
  currentVersion   String?
  metadata         Json?
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category             ProductCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  apiKeyScopes         ApiKeyScope[]
  apiUsageLogs         ApiUsageLog[]
  usageDailyRollups    UsageDailyRollup[]
  partnerProductAccess PartnerProductAccess[]
  docFeedbacks         DocFeedback[]
  changelogs           Changelog[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([visibility])
  @@map("products")
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  products Product[]

  @@map("product_categories")
}

// ─── Partner Management ─────────────────────────────────────────────────────

model PartnerAssignment {
  id           String           @id @default(uuid())
  managerId    String
  partnerOrgId String
  status       AssignmentStatus @default(ACTIVE)
  notes        String?          @db.Text
  assignedAt   DateTime         @default(now())
  createdAt    DateTime         @default(now())

  manager    User         @relation(fields: [managerId], references: [id], onDelete: Cascade)
  partnerOrg Organization @relation(fields: [partnerOrgId], references: [id], onDelete: Cascade)

  @@unique([managerId, partnerOrgId])
  @@index([managerId])
  @@index([partnerOrgId])
  @@map("partner_assignments")
}

model PartnerProductAccess {
  id           String      @id @default(uuid())
  partnerOrgId String
  productId    String
  grantedBy    String
  accessLevel  AccessLevel @default(READ_DOCS)
  grantedAt    DateTime    @default(now())
  expiresAt    DateTime?

  partnerOrg Organization @relation(fields: [partnerOrgId], references: [id], onDelete: Cascade)
  product    Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  grantor    User         @relation(fields: [grantedBy], references: [id], onDelete: Restrict)

  @@unique([partnerOrgId, productId])
  @@index([partnerOrgId])
  @@map("partner_product_access")
}

// ─── API Key Management ─────────────────────────────────────────────────────

model ApiKey {
  id          String            @id @default(uuid())
  userId      String
  name        String
  keyHash     String
  keyPrefix   String            @db.VarChar(8)
  environment ApiKeyEnvironment @default(TEST)
  status      ApiKeyStatus      @default(ACTIVE)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime          @default(now())
  revokedAt   DateTime?

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes           ApiKeyScope[]
  apiUsageLogs     ApiUsageLog[]
  usageDailyRollups UsageDailyRollup[]

  @@index([userId])
  @@index([keyHash])
  @@index([status])
  @@map("api_keys")
}

model ApiKeyScope {
  id          String   @id @default(uuid())
  apiKeyId    String
  productId   String
  permissions String[]

  apiKey  ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([apiKeyId, productId])
  @@map("api_key_scopes")
}

// ─── Usage & Analytics ──────────────────────────────────────────────────────

model ApiUsageLog {
  id             BigInt   @id @default(autoincrement())
  apiKeyId       String
  productId      String
  endpoint       String
  method         String   @db.VarChar(10)
  statusCode     Int      @db.SmallInt
  responseTimeMs Int
  timestamp      DateTime @default(now())

  apiKey  ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([apiKeyId, timestamp])
  @@map("api_usage_logs")
}

model UsageDailyRollup {
  id             BigInt   @id @default(autoincrement())
  apiKeyId       String
  productId      String
  date           DateTime @db.Date
  requestCount   Int
  errorCount     Int
  avgResponseMs  Decimal
  p95ResponseMs  Decimal

  apiKey  ApiKey  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([apiKeyId, productId, date])
  @@index([apiKeyId, productId, date])
  @@map("usage_daily_rollup")
}

// ─── Feedback & Changelogs ──────────────────────────────────────────────────

model DocFeedback {
  id        String   @id @default(uuid())
  userId    String?
  pagePath  String
  productId String?
  helpful   Boolean
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([pagePath])
  @@index([productId])
  @@map("doc_feedback")
}

model Changelog {
  id          String   @id @default(uuid())
  productId   String
  version     String
  title       String
  content     String   @db.Text
  tags        String[]
  publishedAt DateTime
  authorId    String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([productId, publishedAt(sort: Desc)])
  @@map("changelogs")
}
